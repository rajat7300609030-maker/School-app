# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# AdMob Keys: Used to initialize Mobile Ads and serve ads.
# Defaults are the original Google AdMob IDs.
ADMOB_APP_ID=ca-app-pub-3478133934097048~8204011381
ADMOB_BANNER_AD_ID=ca-app-pub-3478133934097048/9097760428
ADMOB_INTERSTITIAL_AD_ID=ca-app-pub-3478133934097048/2599645151
